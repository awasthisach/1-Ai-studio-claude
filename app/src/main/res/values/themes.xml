<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.VvfSmartManager" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/vvf_cosmic_blue</item>
        <item name="android:windowBackground">@color/vvf_surface_light</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>

    <!-- Splash screen shown briefly on cold start (androidx.core:core-splashscreen —
         works from API 23+, uses the real Android 12 SplashScreen API on API 31+).
         Shows the VVF Foundation logo, then hands off to the normal app theme. -->
    <style name="Theme.VvfSmartManager.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/vvf_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.VvfSmartManager</item>
    </style>
</resources>
